# ============================================
# App
# ============================================
NEXT_PUBLIC_ADMIN_EMAIL=phantronghieu1@gmail.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Module 1: Morning Briefing
# ============================================
# OpenAI — used for AI task prioritization (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Google Sheets service account (paste the full JSON as a single-line string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Sheet ID for personal daily tasks (from the sheet URL)
# URL format: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
BRIEFING_SHEET_ID=your-sheet-id-here

# Sheet range to read — columns: A=title, B=notes, C=status ("done" rows are excluded)
BRIEFING_SHEET_RANGE=Sheet1!A:C

# ============================================
# Module 3: Dev Tracker — Google Sheet sync
# ============================================
# Google Sheet ID for dev tasks (columns: A=title, B=description, C=status, D=priority)
# Status values: todo / in_progress / done / blocked
# Priority values: high / medium / low
DEV_TASKS_SHEET_ID=your-sheet-id-here
DEV_TASKS_SHEET_RANGE=Sheet1!A:D

# ============================================
# Module: Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=random-secret-string
TELEGRAM_CHAT_ID=your-chat-id
